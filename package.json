{
  "name": "cyberguard-academy-pro",
  "version": "2.0.0",
  "description": "Professional Cybersecurity Awareness Assessment Platform - Complete Learning & Training System",
  "main": "server-pro.js",
  "type": "commonjs",
  "scripts": {
    "start": "node server-pro.js",
    "dev": "nodemon server-pro.js",
    "test": "echo \"Testing CyberGuard Academy...\" && node server-pro.js",
    "install-deps": "npm install",
